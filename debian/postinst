#!/bin/sh
set -e

echo "[val] Ejecutando postinst..."

mkdir -p /etc/val/val.conf.d
mkdir -p /etc/val/hooks.d
mkdir -p /etc/val/val.sub
mkdir -p /var/lib/val
mkdir -p /var/lib/val/sub

if [ ! -f /var/lib/val/version ]; then
    echo "0" > /var/lib/val/version
fi

systemctl daemon-reload || true
systemctl enable val.service || true

if [ "$1" = "configure" ]; then
    if [ -n "${2:-}" ]; then
        systemctl restart val.service || true
    else
        # Si es una instalación nueva, asegurarse de que el puerto de escucha no esté deshabilitado por defecto.
        VAL_CONF="/etc/val/val.conf"
        if [ -f "$VAL_CONF" ] && grep -q '^BUMP_LISTEN_PORT=0$' "$VAL_CONF" 2>/dev/null; then
            sed -i 's/^BUMP_LISTEN_PORT=0$/BUMP_LISTEN_PORT=9876/' "$VAL_CONF"
            echo "[val] BUMP_LISTEN_PORT=9876 activado en val.conf."
        fi
        systemctl start val.service || true
    fi
fi

echo "[val] Instalacion completada."
exit 0
