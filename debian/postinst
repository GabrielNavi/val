#!/bin/sh
set -e

case "$1" in
    configure)
        mkdir -p /etc/val/val.conf.d /etc/val/hooks.d /etc/val/val.sub \
                 /var/lib/val/sub /var/log/val

        if [ ! -f /var/lib/val/version ]; then
            echo "0" > /var/lib/val/version
        fi

        # Instalación fresca: activar BUMP_LISTEN_PORT para VAL-Aware
        if [ -z "${2:-}" ]; then
            VAL_CONF="/etc/val/val.conf"
            if [ -f "$VAL_CONF" ] && grep -q '^BUMP_LISTEN_PORT=0$' "$VAL_CONF" 2>/dev/null; then
                sed -i 's/^BUMP_LISTEN_PORT=0$/BUMP_LISTEN_PORT=9876/' "$VAL_CONF"
            fi
        fi
        ;;
esac

#DEBHELPER#
