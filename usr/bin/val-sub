#!/bin/bash
# val-sub — Bucle VAL para una sub-instancia de paralelización.
#
# Uso: val-sub <name>
#
#   <name> es el nombre de la carpeta en /etc/val/val.sub/<name>/.
#   Esa carpeta debe contener al menos val.conf con SOURCE o VAS_HOST definido.
#
# Diferencias respecto a val:
#   - Rutas derivadas del nombre: STATE_DIR=/var/lib/val/sub/<name>/
#   - Hereda defaults de /etc/val/val.conf; los sobreescribe con la config de instancia.
#   - HOOKS_DIR por defecto: /etc/val/val.sub/<name>/hooks.d/
#   - LOG_TAG=[NAME-VAL] para identificar en journalctl.
#   - No lanza val-sub-manager (las sub-instancias no se anidan).
#
# Journalctl:
#   journalctl -u val     | grep '\[SAMBA-VAL\]'   # cuando lo lanza val
#   journalctl -u val-sub | grep '\[SAMBA-VAL\]'   # cuando corre standalone

set -euo pipefail

# ---------------------------------------------------------------------------
# Argumento y validación
# ---------------------------------------------------------------------------
if [[ $# -lt 1 || -z "$1" ]]; then
    echo "Uso: val-sub <name>" >&2
    exit 1
fi

NAME="$1"
INSTANCE_DIR="/etc/val/val.sub/${NAME}"

if [[ ! -d "$INSTANCE_DIR" ]]; then
    echo "Error: sub-instancia '$NAME' no encontrada en $INSTANCE_DIR" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Rutas derivadas — definir ANTES de sourcear val-common.sh para que los
# defaults con :- respeten los valores ya establecidos.
# ---------------------------------------------------------------------------
STATE_DIR="/var/lib/val/sub/${NAME}"
CONF_FILE="${INSTANCE_DIR}/val.conf"
CONF_DIR="${INSTANCE_DIR}/val.conf.d"
HOOKS_DIR="${INSTANCE_DIR}/hooks.d"
# shellcheck disable=SC2034  # LOG_TAG es usado por log()/log_debug() en val-common.sh
LOG_TAG="[${NAME^^}-VAL]"
# shellcheck source=/usr/lib/val/val-common.sh
source /usr/lib/val/val-common.sh

# ---------------------------------------------------------------------------
# Carga de configuración: base (herencia) + instancia (override)
# ---------------------------------------------------------------------------
load_conf "/etc/val/val.conf"
load_conf "$CONF_FILE"
if [[ -d "$CONF_DIR" ]]; then
    for cfg in "$CONF_DIR"/*.conf; do
        [[ -f "$cfg" ]] || continue
        load_conf "$cfg"
    done
fi
_normalize_vas_host
# Re-aplicar rutas de instancia: load_conf hereda val.conf y puede sobreescribirlas.
HOOKS_DIR="${INSTANCE_DIR}/hooks.d"
# Sub-instancias no heredan el BUMP_LISTEN_PORT del principal (evita conflicto de puerto).
# Cada sub-instancia debe configurar su propio puerto en su val.conf si lo necesita.
[[ -z "$(grep -s "^BUMP_LISTEN_PORT" "$CONF_FILE")" ]] && BUMP_LISTEN_PORT=0

# ---------------------------------------------------------------------------
# Inicialización
# ---------------------------------------------------------------------------
mkdir -p "$STATE_DIR"

if [[ ! -f "$VERSION_FILE" ]]; then
    echo "0" > "$VERSION_FILE"
fi

if [[ "$BUMP_LISTEN_PORT" != "0" ]] && ! command -v nc &>/dev/null; then
    log "[WARN] BUMP_LISTEN_PORT=$BUMP_LISTEN_PORT pero nc no está instalado (instala netcat-openbsd). VAL-Aware desactivado."
    BUMP_LISTEN_PORT=0
fi

log "=== Iniciando ${NAME}-val ==="
log "SOURCE:           $SOURCE"
log "FILTER:           $FILTER"
log "CHECK:            ${CHECK_SECONDS}s"
log "RETRY:            ${RETRY_SECONDS}s"
log "HOOKS_DIR:        $HOOKS_DIR"
log "STATE_DIR:        $STATE_DIR"
log "GLOBAL_KEY:       ${GLOBAL_KEY:-(ninguna)}"
log "LOCAL_KEY_LIST:   ${LOCAL_KEY_LIST:-(ninguna)}"
log "DISPATCH_STDIN:   $DISPATCH_STDIN"
log "HOOK_TIMEOUT:     ${HOOK_TIMEOUT_SECONDS}s ($([ "$HOOK_TIMEOUT_SECONDS" != "0" ] && echo 'activo' || echo 'desactivado'))"
log "BUMP_LISTEN_PORT: $BUMP_LISTEN_PORT ($([ "$BUMP_LISTEN_PORT" != "0" ] && echo 'activo' || echo 'desactivado'))"
log "USE_VAT:          $USE_VAT"
[[ "$USE_VAT" == "true" ]] && log "VAT_PRESET:       $VAT_PRESET"
[[ "$SOURCE" == "vas" ]] && log "VAS_HOST:         ${VAS_HOST:-'(no definido)'}"
[[ "$SOURCE" == "vac" ]] && log "VAC_STATE_DIR:    $VAC_STATE_DIR"

case "$FILTER" in
    active|inactive|archived|all) ;;
    *)
        log "ERROR: FILTER inválido: '$FILTER'. Valores válidos: active, inactive, archived, all."
        exit 1
        ;;
esac

if [[ "$SOURCE" == "vac" && "$FILTER" != "active" ]]; then
    log "AVISO: SOURCE=vac descarga solo clientes activos. FILTER=$FILTER puede dar resultados incompletos."
fi

if [[ "$SOURCE" == "vac" && -n "$GLOBAL_KEY" ]]; then
    log "AVISO: GLOBAL_KEY=$GLOBAL_KEY ignorada con SOURCE=vac."
fi

# ---------------------------------------------------------------------------
# Bump listener (VAL-Aware)
# ---------------------------------------------------------------------------
BUMP_PID=""
BUMP_FIFO="/var/run/val/sub/${NAME}.bump.fifo"

cleanup() {
    [[ -n "$BUMP_PID" ]] && kill "$BUMP_PID" 2>/dev/null || true
    [[ -e "$BUMP_FIFO" ]] && rm -f "$BUMP_FIFO" || true
    exit 0
}
trap cleanup SIGTERM SIGINT

if [[ "$BUMP_LISTEN_PORT" != "0" ]]; then
    mkdir -p "$(dirname "$BUMP_FIFO")"
    mkfifo "$BUMP_FIFO" 2>/dev/null || true
    exec 3<>"$BUMP_FIFO"
    nc -u -l -k -p "$BUMP_LISTEN_PORT" >"$BUMP_FIFO" &
    BUMP_PID=$!
    log "[BUMP] Escuchando UDP en puerto $BUMP_LISTEN_PORT (PID $BUMP_PID)"
fi

# ---------------------------------------------------------------------------
# Bucle principal
# ---------------------------------------------------------------------------
while true; do
    log "--- Ciclo iniciado ---"

    if [[ "$SOURCE" == "vas" && -z "$VAS_HOST" ]]; then
        log "VAS_HOST no definido. Esperando ${RETRY_SECONDS}s."
        sleep "$RETRY_SECONDS"
        continue
    fi

    local_version="$(tr -d '[:space:]' < "$VERSION_FILE")"
    remote_version="$(get_remote_version)"

    if [[ -z "$remote_version" ]]; then
        log "[VERSION] No se pudo obtener versión remota. Reintentando en ${RETRY_SECONDS}s."
        sleep "$RETRY_SECONDS"
        continue
    fi

    if [[ ! "$remote_version" =~ ^[0-9]+$ ]]; then
        log "[VERSION] Versión remota inválida: '$remote_version'. Reintentando en ${RETRY_SECONDS}s."
        sleep "$RETRY_SECONDS"
        continue
    fi

    if [[ "$remote_version" == "$local_version" ]]; then
        log "[VERSION] Sin cambios. Próxima comprobación en ${CHECK_SECONDS}s."
        interruptible_sleep "$CHECK_SECONDS"
        continue
    fi

    log "[SYNC] Nueva versión detectada: $local_version → $remote_version"

    if ! fetch_clients; then
        log "[VAL-ERROR] No se pudo obtener el inventario. Reintentando en ${RETRY_SECONDS}s."
        sleep "$RETRY_SECONDS"
        continue
    fi

    materialize_keys
    dispatch_hooks "$remote_version"

    echo "$remote_version" > "$VERSION_FILE"
    log "[SYNC] Versión local actualizada: $remote_version"
    log "--- Ciclo completado. Próxima comprobación en ${CHECK_SECONDS}s. ---"
    interruptible_sleep "$CHECK_SECONDS"
done
