#!/bin/bash
# val-sub-instance — Gestión de sub-instancias VAL.
#
# Uso:
#   val-sub-instance --create NAME [--vas URL | --source vac]
#   val-sub-instance --delete NAME
#   val-sub-instance --list
#
# --create NAME
#   Crea /etc/val/val.sub/<NAME>/ con val.conf, conf.d/ y hooks.d/.
#   Parte de /usr/share/val/val.conf.defaults y ajusta SOURCE/VAS_HOST.
#   --vas URL   → SOURCE=vas, VAS_HOST=URL  (por defecto)
#   --source vac → SOURCE=vac, sin VAS_HOST
#
# --delete NAME
#   Elimina la configuración (/etc/val/val.sub/<NAME>/) y el estado
#   (/var/lib/val/sub/<NAME>/). Aborta si val-sub está en ejecución.
#
# --list
#   Tabla con NAME, SOURCE/HOST y estado (activa/parada/nueva).

set -euo pipefail

TEMPLATE_FILE="/usr/share/val/instance-template/val.conf"
SUB_CONFIG_BASE="/etc/val/val.sub"
SUB_STATE_BASE="/var/lib/val/sub"

usage() {
    cat >&2 <<'EOF'
Uso:
  val-sub-instance --create NAME [--vas URL | --source vac]
  val-sub-instance --delete NAME
  val-sub-instance --list
EOF
    exit 1
}

# ---------------------------------------------------------------------------
# Parseo de argumentos
# ---------------------------------------------------------------------------
ACTION=""
NAME=""
VAS_URL=""
SOURCE_VAL="vas"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --create) ACTION="create"; NAME="${2:-}"; shift 2 ;;
        --delete) ACTION="delete"; NAME="${2:-}"; shift 2 ;;
        --list)   ACTION="list";                  shift   ;;
        --vas)    VAS_URL="${2:-}"; SOURCE_VAL="vas"; shift 2 ;;
        --source) SOURCE_VAL="${2:-}"; shift 2 ;;
        *) echo "Opción desconocida: $1" >&2; usage ;;
    esac
done

[[ -z "$ACTION" ]] && usage

# ---------------------------------------------------------------------------
# Validación de NAME
# ---------------------------------------------------------------------------
validate_name() {
    local n="$1"
    [[ -z "$n" ]] && { echo "Error: NAME no puede estar vacío." >&2; exit 1; }
    [[ "$n" =~ ^[a-zA-Z0-9_-]+$ ]] || {
        echo "Error: NAME solo puede contener letras, dígitos, guiones y subrayados." >&2
        exit 1
    }
}

# ---------------------------------------------------------------------------
# Acción: --create
# ---------------------------------------------------------------------------
do_create() {
    validate_name "$NAME"

    local instance_dir="${SUB_CONFIG_BASE}/${NAME}"
    if [[ -d "$instance_dir" ]]; then
        echo "Error: la sub-instancia '${NAME}' ya existe en ${instance_dir}." >&2
        exit 1
    fi

    if [[ "$SOURCE_VAL" == "vas" && -z "$VAS_URL" ]]; then
        echo "Error: --vas URL es obligatorio con SOURCE=vas." >&2
        exit 1
    fi

    if [[ ! -f "$TEMPLATE_FILE" ]]; then
        echo "Error: no se encontró $TEMPLATE_FILE." >&2
        exit 1
    fi

    mkdir -p "${instance_dir}/val.conf.d"
    mkdir -p "${instance_dir}/hooks.d"

    # Generar val.conf desde template, ajustando SOURCE y VAS_HOST
    local conf_out="${instance_dir}/val.conf"
    sed \
        -e "s|^SOURCE=.*|SOURCE=${SOURCE_VAL}|" \
        -e "s|^VAS_HOST=.*|VAS_HOST=${VAS_URL}|" \
        "$TEMPLATE_FILE" > "$conf_out"

    # Activar la instancia por defecto (rm .enabled para desactivar sin borrar)
    touch "${instance_dir}/.enabled"

    echo "Sub-instancia '${NAME}' creada y activada:"
    echo "  Configuración: ${conf_out}"
    echo "  Hooks:         ${instance_dir}/hooks.d/"
    echo "  Overlays:      ${instance_dir}/val.conf.d/"
    echo "  .enabled:      ${instance_dir}/.enabled (rm para desactivar)"
    echo ""
    echo "Para aplicar: systemctl restart val  (o val-sub si usa el servicio independiente)"
}

# ---------------------------------------------------------------------------
# Acción: --delete
# ---------------------------------------------------------------------------
do_delete() {
    validate_name "$NAME"

    local instance_dir="${SUB_CONFIG_BASE}/${NAME}"
    local state_dir="${SUB_STATE_BASE}/${NAME}"

    if [[ ! -d "$instance_dir" ]]; then
        echo "Error: la sub-instancia '${NAME}' no existe en ${instance_dir}." >&2
        exit 1
    fi

    # Comprobar si el proceso está activo
    if pgrep -f "val-sub ${NAME}$" > /dev/null 2>&1; then
        echo "Error: val-sub '${NAME}' está en ejecución. Detén el servicio antes de eliminar." >&2
        exit 1
    fi

    rm -rf "$instance_dir"
    echo "Configuración eliminada: ${instance_dir}"

    if [[ -d "$state_dir" ]]; then
        rm -rf "$state_dir"
        echo "Estado eliminado:        ${state_dir}"
    fi

    echo "Sub-instancia '${NAME}' eliminada."
}

# ---------------------------------------------------------------------------
# Acción: --list
# ---------------------------------------------------------------------------
do_list() {
    if [[ ! -d "$SUB_CONFIG_BASE" ]]; then
        echo "No existe el directorio de sub-instancias: $SUB_CONFIG_BASE"
        exit 0
    fi

    local found=0
    printf "%-20s %-10s %-30s %-8s %s\n" "NOMBRE" "SOURCE" "VAS_HOST / VAC_STATE_DIR" "ENABLED" "ESTADO"
    printf "%-20s %-10s %-30s %-8s %s\n" "------" "------" "------------------------" "-------" "------"

    for instance_dir in "$SUB_CONFIG_BASE"/*/; do
        [[ -d "$instance_dir" ]] || continue
        local name
        name="$(basename "$instance_dir")"
        [[ -f "${instance_dir}/val.conf" ]] || continue

        local src host enabled status
        src="$(grep -E '^SOURCE\s*=' "${instance_dir}/val.conf" \
            | head -1 | cut -d= -f2- | tr -d '"' | xargs 2>/dev/null || echo 'vas')"
        host="$(grep -E '^VAS_HOST\s*=' "${instance_dir}/val.conf" \
            | head -1 | cut -d= -f2- | tr -d '"' | xargs 2>/dev/null || echo '')"
        [[ "$src" == "vac" ]] && host="$(grep -E '^VAC_STATE_DIR\s*=' \
            "${instance_dir}/val.conf" | head -1 | cut -d= -f2- | tr -d '"' \
            | xargs 2>/dev/null || echo '/var/lib/vac')"
        enabled="$( [[ -f "${instance_dir}/.enabled" ]] && echo "sí" || echo "no")"

        if pgrep -f "val-sub ${name}$" > /dev/null 2>&1; then
            status="activa"
        elif [[ -d "${SUB_STATE_BASE}/${name}" ]]; then
            status="parada"
        else
            status="nueva"
        fi

        printf "%-20s %-10s %-30s %-8s %s\n" "$name" "$src" "${host:--}" "$enabled" "$status"
        (( ++found ))
    done

    [[ $found -eq 0 ]] && echo "(ninguna sub-instancia configurada)"
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
case "$ACTION" in
    create) do_create ;;
    delete) do_delete ;;
    list)   do_list   ;;
esac
