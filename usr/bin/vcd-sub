#!/bin/bash
# vcd-sub — Bucle VCD para una sub-instancia de paralelización.
#
# Uso: vcd-sub <name>
#
#   <name> es el nombre de la carpeta en /etc/vcd/vcd.sub/<name>/.
#   Esa carpeta debe contener al menos vcd.conf con SOURCE o VAS_HOST definido.
#
# Diferencias respecto a vcd:
#   - Rutas derivadas del nombre: STATE_DIR=/var/lib/vcd/sub/<name>/
#   - Hereda defaults de /etc/vcd/vcd.conf; los sobreescribe con la config de instancia.
#   - HOOKS_DIR por defecto: /etc/vcd/vcd.sub/<name>/hooks.d/
#   - LOG_TAG=[NAME-VCD] para identificar en journalctl.
#   - No lanza vcd-sub-manager (las sub-instancias no se anidan).
#
# Journalctl:
#   journalctl -u vcd     | grep '\[SAMBA-VCD\]'   # cuando lo lanza vcd
#   journalctl -u vcd-sub | grep '\[SAMBA-VCD\]'   # cuando corre standalone

set -euo pipefail

# ---------------------------------------------------------------------------
# Argumento y validación
# ---------------------------------------------------------------------------
if [[ $# -lt 1 || -z "$1" ]]; then
    echo "Uso: vcd-sub <name>" >&2
    exit 1
fi

NAME="$1"
INSTANCE_DIR="/etc/vcd/vcd.sub/${NAME}"

if [[ ! -d "$INSTANCE_DIR" ]]; then
    echo "Error: sub-instancia '$NAME' no encontrada en $INSTANCE_DIR" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Rutas derivadas — definidas ANTES de load_conf para que los defaults
# de la instancia puedan sobreescribir HOOKS_DIR si el admin lo desea
# ---------------------------------------------------------------------------
STATE_DIR="/var/lib/vcd/sub/${NAME}"
VERSION_FILE="${STATE_DIR}/version"
CLIENTS_FILE="${STATE_DIR}/clients.json"
TMP_CLIENTS="${STATE_DIR}/clients.json.tmp"
CONF_FILE="${INSTANCE_DIR}/vcd.conf"
CONF_DIR="${INSTANCE_DIR}/vcd.conf.d"
LOG_TAG="[${NAME^^}-VCD]"

# ---------------------------------------------------------------------------
# Defaults de configuración (heredados de /etc/vcd/vcd.conf y sobreescritos
# por la config de instancia)
# ---------------------------------------------------------------------------
SOURCE="vas"
VAS_HOST=""
VAC_STATE_DIR="/var/lib/vac"
FILTER="active"
CHECK_SECONDS=300
RETRY_SECONDS=60
HOOKS_DIR="${INSTANCE_DIR}/hooks.d"
GLOBAL_KEY=""
LOCAL_KEY_LIST=""
DISPATCH_STDIN="true"
BUMP_LISTEN_PORT="0"

# ---------------------------------------------------------------------------
# Carga de configuración
# ---------------------------------------------------------------------------
load_conf() {
    local file="$1"
    [ -f "$file" ] || return 0
    local loaded=0
    while IFS='=' read -r key val; do
        key="$(echo "$key" | xargs 2>/dev/null || true)"
        val="$(echo "$val" | xargs 2>/dev/null | sed 's/^"//; s/"$//' || true)"
        [ -z "$key" ] && continue
        case "$key" in
            SOURCE)           SOURCE="$val";           (( ++loaded )) ;;
            VAS_HOST)         VAS_HOST="$val";         (( ++loaded )) ;;
            VAC_STATE_DIR)    VAC_STATE_DIR="$val";    (( ++loaded )) ;;
            FILTER)           FILTER="$val";           (( ++loaded )) ;;
            CHECK_SECONDS)    CHECK_SECONDS="$val";    (( ++loaded )) ;;
            RETRY_SECONDS)    RETRY_SECONDS="$val";    (( ++loaded )) ;;
            HOOKS_DIR)        HOOKS_DIR="$val";        (( ++loaded )) ;;
            GLOBAL_KEY)       GLOBAL_KEY="$val";       (( ++loaded )) ;;
            LOCAL_KEY_LIST)   LOCAL_KEY_LIST="$val";   (( ++loaded )) ;;
            DISPATCH_STDIN)   DISPATCH_STDIN="$val";   (( ++loaded )) ;;
            BUMP_LISTEN_PORT) BUMP_LISTEN_PORT="$val"; (( ++loaded )) ;;
        esac
    done < <(grep -v '^\s*#' "$file" | grep '=' || true)
}

load_conf "/etc/vcd/vcd.conf"
load_conf "$CONF_FILE"
if [[ -d "$CONF_DIR" ]]; then
    for cfg in "$CONF_DIR"/*.conf; do
        [[ -f "$cfg" ]] || continue
        load_conf "$cfg"
    done
fi

# ---------------------------------------------------------------------------
# Inicialización
# ---------------------------------------------------------------------------
mkdir -p "$STATE_DIR"

if [[ ! -f "$VERSION_FILE" ]]; then
    echo "0" > "$VERSION_FILE"
fi

log() { echo "$LOG_TAG $*" >&2; }

log "=== Iniciando ${NAME}-vcd ==="
log "SOURCE:           $SOURCE"
log "FILTER:           $FILTER"
log "CHECK:            ${CHECK_SECONDS}s"
log "RETRY:            ${RETRY_SECONDS}s"
log "HOOKS_DIR:        $HOOKS_DIR"
log "STATE_DIR:        $STATE_DIR"
log "GLOBAL_KEY:       ${GLOBAL_KEY:-(ninguna)}"
log "LOCAL_KEY_LIST:   ${LOCAL_KEY_LIST:-(ninguna)}"
log "DISPATCH_STDIN:   $DISPATCH_STDIN"
log "BUMP_LISTEN_PORT: $BUMP_LISTEN_PORT ($([ "$BUMP_LISTEN_PORT" != "0" ] && echo 'activo' || echo 'desactivado'))"
[[ "$SOURCE" == "vas" ]] && log "VAS_HOST:         ${VAS_HOST:-'(no definido)'}"
[[ "$SOURCE" == "vac" ]] && log "VAC_STATE_DIR:    $VAC_STATE_DIR"

case "$FILTER" in
    active|inactive|archived|all) ;;
    *)
        log "ERROR: FILTER inválido: '$FILTER'. Valores válidos: active, inactive, archived, all."
        exit 1
        ;;
esac

if [[ "$SOURCE" == "vac" && "$FILTER" != "active" ]]; then
    log "AVISO: SOURCE=vac descarga solo clientes activos. FILTER=$FILTER puede dar resultados incompletos."
fi

if [[ "$SOURCE" == "vac" && -n "$GLOBAL_KEY" ]]; then
    log "AVISO: GLOBAL_KEY=$GLOBAL_KEY ignorada con SOURCE=vac."
fi

# ---------------------------------------------------------------------------
# Bump listener (VCD-Aware)
# ---------------------------------------------------------------------------
BUMP_PID=""
BUMP_FIFO="/var/run/vcd/sub/${NAME}.bump.fifo"

interruptible_sleep() {
    if [[ "$BUMP_LISTEN_PORT" != "0" ]]; then
        read -t "$1" -r _bump <&3 2>/dev/null || true
    else
        sleep "$1"
    fi
}

cleanup() {
    [[ -n "$BUMP_PID" ]] && kill "$BUMP_PID" 2>/dev/null || true
    [[ -e "$BUMP_FIFO" ]] && rm -f "$BUMP_FIFO" || true
    exit 0
}
trap cleanup SIGTERM SIGINT

if [[ "$BUMP_LISTEN_PORT" != "0" ]]; then
    mkdir -p "$(dirname "$BUMP_FIFO")"
    mkfifo "$BUMP_FIFO" 2>/dev/null || true
    exec 3<>"$BUMP_FIFO"
    nc -u -l -k -p "$BUMP_LISTEN_PORT" >"$BUMP_FIFO" &
    BUMP_PID=$!
    log "[BUMP] Escuchando UDP en puerto $BUMP_LISTEN_PORT (PID $BUMP_PID)"
fi

# ---------------------------------------------------------------------------
# Funciones
# ---------------------------------------------------------------------------
get_remote_version() {
    local ver=""
    case "$SOURCE" in
        vas)
            ver="$(curl -fsS --max-time 10 --connect-timeout 5 \
                "${VAS_HOST%/}/version" 2>/dev/null \
                | jq -r '.version' 2>/dev/null || echo "")"
            ;;
        vac)
            local vac_version="${VAC_STATE_DIR}/version"
            [[ -f "$vac_version" ]] && ver="$(tr -d '[:space:]' < "$vac_version")"
            ;;
    esac
    echo "$ver"
}

fetch_clients() {
    case "$SOURCE" in
        vas)
            local url="${VAS_HOST%/}/clients"
            local params=""
            [[ "$FILTER" != "active" ]] && params="status=${FILTER}"
            [[ -n "$GLOBAL_KEY" ]] && params="${params:+${params}&}extra_key=${GLOBAL_KEY}"
            [[ -n "$params" ]] && url="${url}?${params}"
            log "[FETCH] Descargando inventario desde $url"
            if curl -fsS --max-time 15 --connect-timeout 5 \
                "$url" -o "$TMP_CLIENTS" 2>/dev/null; then
                local count
                count="$(jq '.clients | length' "$TMP_CLIENTS" 2>/dev/null || echo '?')"
                mv "$TMP_CLIENTS" "$CLIENTS_FILE"
                log "[FETCH] Inventario guardado: $count equipo(s)"
                return 0
            else
                log "[VCD-ERROR] Error descargando inventario."
                rm -f "$TMP_CLIENTS"
                return 1
            fi
            ;;
        vac)
            local vac_clients="${VAC_STATE_DIR}/clients.json"
            if [[ -f "$vac_clients" ]]; then
                cp "$vac_clients" "$CLIENTS_FILE"
                local count
                count="$(jq '.clients | length' "$CLIENTS_FILE" 2>/dev/null || echo '?')"
                log "[FETCH] Inventario copiado desde VAC: $count equipo(s)"
                return 0
            else
                log "[VCD-ERROR] No se encontró ${vac_clients}."
                return 1
            fi
            ;;
    esac
}

materialize_keys() {
    [[ -z "$LOCAL_KEY_LIST" ]] && return 0
    [[ ! -f "$CLIENTS_FILE" ]] && return 0
    for key in $LOCAL_KEY_LIST; do
        local out="${STATE_DIR}/${key}_clients.json"
        local tmp="${out}.tmp"
        if jq --arg key "$key" \
            '{clients: [.clients[]? | select(
                (.extra_imperative  and (.extra_imperative  | has($key))) or
                (.extra_informative and (.extra_informative | has($key)))
            )]}' "$CLIENTS_FILE" > "$tmp" 2>/dev/null; then
            mv "$tmp" "$out"
            local count
            count="$(jq '.clients | length' "$out" 2>/dev/null || echo '?')"
            log "[MATERIALIZE] ${key}_clients.json → $count equipo(s)"
        else
            log "[VCD-ERROR] Error materializando ${key}_clients.json"
            rm -f "$tmp"
        fi
    done
}

dispatch_hooks() {
    local version="$1"
    [[ ! -d "$HOOKS_DIR" ]] && { log "[HOOKS] Directorio no encontrado: $HOOKS_DIR"; return 0; }

    local hook_count=0 hook_errors=0
    local stdin_src="$CLIENTS_FILE"
    [[ "$DISPATCH_STDIN" != "true" ]] && stdin_src="/dev/null"

    for hook in "$HOOKS_DIR"/*; do
        [[ -f "$hook" && -x "$hook" ]] || continue
        (( ++hook_count ))
        log "[HOOKS] Ejecutando: $(basename "$hook")"
        if VCD_VERSION="$version" \
           VCD_FILTER="$FILTER" \
           VCD_SOURCE="$SOURCE" \
           VCD_EXTRA_KEY="$GLOBAL_KEY" \
           VCD_STATE_DIR="$STATE_DIR" \
           "$hook" < "$stdin_src"; then
            log "[HOOKS] OK: $(basename "$hook")"
        else
            log "[VCD-ERROR] Hook $(basename "$hook") terminó con error."
            (( ++hook_errors ))
        fi
    done

    [[ $hook_count -eq 0 ]] && log "[HOOKS] Sin hooks ejecutables en $HOOKS_DIR" || \
        log "[HOOKS] $hook_count hook(s), $hook_errors error(es)"
}

# ---------------------------------------------------------------------------
# Bucle principal
# ---------------------------------------------------------------------------
while true; do
    log "--- Ciclo iniciado ---"

    if [[ "$SOURCE" == "vas" && -z "$VAS_HOST" ]]; then
        log "VAS_HOST no definido. Esperando ${RETRY_SECONDS}s."
        sleep "$RETRY_SECONDS"
        continue
    fi

    local_version="$(tr -d '[:space:]' < "$VERSION_FILE")"
    remote_version="$(get_remote_version)"

    if [[ -z "$remote_version" ]]; then
        log "[VERSION] No se pudo obtener versión remota. Reintentando en ${RETRY_SECONDS}s."
        sleep "$RETRY_SECONDS"
        continue
    fi

    if [[ ! "$remote_version" =~ ^[0-9]+$ ]]; then
        log "[VERSION] Versión remota inválida: '$remote_version'. Reintentando en ${RETRY_SECONDS}s."
        sleep "$RETRY_SECONDS"
        continue
    fi

    if [[ "$remote_version" == "$local_version" ]]; then
        log "[VERSION] Sin cambios. Próxima comprobación en ${CHECK_SECONDS}s."
        interruptible_sleep "$CHECK_SECONDS"
        continue
    fi

    log "[SYNC] Nueva versión detectada: $local_version → $remote_version"

    if ! fetch_clients; then
        log "[VCD-ERROR] No se pudo obtener el inventario. Reintentando en ${RETRY_SECONDS}s."
        sleep "$RETRY_SECONDS"
        continue
    fi

    materialize_keys
    dispatch_hooks "$remote_version"

    echo "$remote_version" > "$VERSION_FILE"
    log "[SYNC] Versión local actualizada: $remote_version"
    log "--- Ciclo completado. Próxima comprobación en ${CHECK_SECONDS}s. ---"
    interruptible_sleep "$CHECK_SECONDS"
done
